[sub_resource type="GDScript" id="GDScript_dbkkn"]
script/source = "extends StaticBody3D

# Reference to the popup scene instance (add as a child in the editor)
@onready var popup: Control = $LogisticsPopup

# Reference to the player so the popup can call back to close
@export var player_path: NodePath
@onready var player = get_node(player_path)


func _ready() -> void:
	popup.visible = false
	# Pass player reference to popup so it can trigger close
	popup.player = player


func open_popup() -> void:
	popup.visible = true
	popup.refresh()  # Re-draw current allocations when opened


func close_popup() -> void:
	popup.visible = false
"

