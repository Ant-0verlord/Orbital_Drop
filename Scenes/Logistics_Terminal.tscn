[sub_resource type="GDScript" id="GDScript_i6nf8"]
resource_name = "LogisticsPopup"
script/source = "extends Control

# ---------------------------------------------------------
# LogisticsPopup.gd
# Attach to a CanvasLayer > Control popup scene.
# Layout (build in the editor or via code below):
#   - Title label
#   - Budget remaining label
#   - ScrollContainer with a VBoxContainer of squad rows
#   - Each squad row: Label (name) + 3 OptionButtons (Armaments / Medi-Packs / Fuel Cells) + cost label
#   - Close button
# ---------------------------------------------------------

var player = null  # Set by LogisticsTerminal before opening

const TOTAL_BUDGET: int = 12  # Total logistics points per turn
const SUPPLY_COST: Dictionary = {
	\"None\": 0,
	\"Armaments\": 2,
	\"Medi-Packs\": 2,
	\"Fuel Cells\": 2,
}
const SUPPLY_OPTIONS: Array = [\"None\", \"Armaments\", \"Medi-Packs\", \"Fuel Cells\"]

# Allocation state — persists between openings
# Structure: { squad_name: { \"Armaments\": int, \"Medi-Packs\": int, \"Fuel Cells\": int } }
# Initialised by AllocationManager or set here for standalone testing
var allocations: Dictionary = {}

# Squad list — in a real game this comes from AllocationManager / SquadData resources
var squads: Array = [
	{ \"name\": \"Squad Varro\",   \"status\": \"Advancing\",  \"sector\": \"Alpha-7\" },
	{ \"name\": \"Squad Kael\",    \"status\": \"Pinned\",     \"sector\": \"Beta-2\"  },
	{ \"name\": \"Squad Orin\",    \"status\": \"Wounded\",    \"sector\": \"Gamma-5\" },
]

# UI node references (assigned in _ready)
var budget_label: Label
var squad_container: VBoxContainer
var warning_label: Label
var squad_rows: Array = []  # Holds per-squad UI data for easy refresh


func _ready() -> void:
	_build_ui()
	_init_allocations()


func _init_allocations() -> void:
	for squad in squads:
		if not allocations.has(squad[\"name\"]):
			allocations[squad[\"name\"]] = { \"Armaments\": 0, \"Medi-Packs\": 0, \"Fuel Cells\": 0 }


# -------------------------------------------------------
# Build the popup UI in code (alternatively, build in editor)
# -------------------------------------------------------
func _build_ui() -> void:
	# Root panel
	custom_minimum_size = Vector2(520, 0)
	set_anchors_preset(Control.PRESET_CENTER)

	var panel := PanelContainer.new()
	panel.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	add_child(panel)

	var vbox := VBoxContainer.new()
	vbox.add_theme_constant_override(\"separation\", 12)
	panel.add_child(vbox)

	# Title
	var title := Label.new()
	title.text = \"LOGISTICS TERMINAL\"
	title.add_theme_font_size_override(\"font_size\", 18)
	vbox.add_child(title)

	# Budget label
	budget_label = Label.new()
	budget_label.add_theme_font_size_override(\"font_size\", 14)
	vbox.add_child(budget_label)

	# Warning label (shown when budget exceeded or no allocations)
	warning_label = Label.new()
	warning_label.add_theme_color_override(\"font_color\", Color(1, 0.3, 0.3))
	warning_label.text = \"\"
	warning_label.autowrap_mode = TextServer.AUTOWRAP_WORD
	vbox.add_child(warning_label)

	# Separator
	vbox.add_child(HSeparator.new())

	# Squad rows header
	var header := HBoxContainer.new()
	header.add_theme_constant_override(\"separation\", 8)
	var h_squad := Label.new(); h_squad.text = \"Squad\"; h_squad.custom_minimum_size.x = 110
	var h_status := Label.new(); h_status.text = \"Status\"; h_status.custom_minimum_size.x = 80
	var h_arm := Label.new(); h_arm.text = \"Armaments\"; h_arm.custom_minimum_size.x = 110
	var h_med := Label.new(); h_med.text = \"Medi-Packs\"; h_med.custom_minimum_size.x = 110
	var h_fuel := Label.new(); h_fuel.text = \"Fuel Cells\"; h_fuel.custom_minimum_size.x = 110
	for lbl in [h_squad, h_status, h_arm, h_med, h_fuel]:
		lbl.add_theme_font_size_override(\"font_size\", 12)
		header.add_child(lbl)
	vbox.add_child(header)

	vbox.add_child(HSeparator.new())

	# Squad rows
	squad_container = VBoxContainer.new()
	squad_container.add_theme_constant_override(\"separation\", 8)
	vbox.add_child(squad_container)

	for i in squads.size():
		var row_data = _build_squad_row(squads[i], i)
		squad_rows.append(row_data)
		squad_container.add_child(row_data[\"row\"])

	vbox.add_child(HSeparator.new())

	# Confirm / Close buttons
	var btn_row := HBoxContainer.new()
	btn_row.add_theme_constant_override(\"separation\", 12)
	btn_row.alignment = BoxContainer.ALIGNMENT_END
	vbox.add_child(btn_row)

	var confirm_btn := Button.new()
	confirm_btn.text = \"Confirm Allocations\"
	confirm_btn.pressed.connect(_on_confirm_pressed)
	btn_row.add_child(confirm_btn)

	var close_btn := Button.new()
	close_btn.text = \"Close  [Esc]\"
	close_btn.pressed.connect(_on_close_pressed)
	btn_row.add_child(close_btn)


func _build_squad_row(squad: Dictionary, index: int) -> Dictionary:
	var row := HBoxContainer.new()
	row.add_theme_constant_override(\"separation\", 8)

	var name_lbl := Label.new()
	name_lbl.text = squad[\"name\"]
	name_lbl.custom_minimum_size.x = 110
	name_lbl.add_theme_font_size_override(\"font_size\", 13)
	row.add_child(name_lbl)

	var status_lbl := Label.new()
	status_lbl.text = squad[\"status\"]
	status_lbl.custom_minimum_size.x = 80
	status_lbl.add_theme_font_size_override(\"font_size\", 13)
	row.add_child(status_lbl)

	# One OptionButton per supply type
	var dropdowns: Dictionary = {}
	for supply in [\"Armaments\", \"Medi-Packs\", \"Fuel Cells\"]:
		var opt := OptionButton.new()
		opt.custom_minimum_size.x = 110
		for option in SUPPLY_OPTIONS:
			opt.add_item(option)
		opt.selected = 0  # Default: None
		opt.item_selected.connect(_on_supply_changed.bind(squad[\"name\"], supply, opt))
		row.add_child(opt)
		dropdowns[supply] = opt

	return { \"row\": row, \"dropdowns\": dropdowns, \"squad\": squad[\"name\"] }


# -------------------------------------------------------
# Logic
# -------------------------------------------------------
func _on_supply_changed(_index: int, squad_name: String, supply: String, opt: OptionButton) -> void:
	var chosen: String = SUPPLY_OPTIONS[opt.selected]
	allocations[squad_name][supply] = SUPPLY_COST[chosen]
	_refresh_budget()


func _refresh_budget() -> void:
	var spent: int = 0
	for squad_name in allocations:
		for supply in allocations[squad_name]:
			spent += allocations[squad_name][supply]
	var remaining: int = TOTAL_BUDGET - spent
	budget_label.text = \"Budget:  %d / %d  (%d remaining)\" % [spent, TOTAL_BUDGET, remaining]
	if remaining < 0:
		warning_label.text = \"Over budget! Remove some allocations.\"
		budget_label.add_theme_color_override(\"font_color\", Color(1, 0.3, 0.3))
	else:
		warning_label.text = \"\"
		budget_label.remove_theme_color_override(\"font_color\")


func _on_confirm_pressed() -> void:
	var spent: int = 0
	for squad_name in allocations:
		for supply in allocations[squad_name]:
			spent += allocations[squad_name][supply]
	if spent > TOTAL_BUDGET:
		warning_label.text = \"Cannot confirm — over budget!\"
		return
	# Allocations are locked in — AllocationManager would read allocations here
	warning_label.text = \"\"
	print(\"Allocations confirmed: \", allocations)
	_on_close_pressed()


func _on_close_pressed() -> void:
	visible = false
	if player and player.has_method(\"on_popup_closed\"):
		player.on_popup_closed()


# Called by LogisticsTerminal.open_popup() to sync dropdown state with saved allocations
func refresh() -> void:
	_init_allocations()
	for row_data in squad_rows:
		var squad_name: String = row_data[\"squad\"]
		for supply in [\"Armaments\", \"Medi-Packs\", \"Fuel Cells\"]:
			var saved_cost: int = allocations[squad_name][supply]
			var opt: OptionButton = row_data[\"dropdowns\"][supply]
			# Find the option that matches the saved cost
			for i in SUPPLY_OPTIONS.size():
				if SUPPLY_COST[SUPPLY_OPTIONS[i]] == saved_cost:
					opt.selected = i
					break
	_refresh_budget()
"

